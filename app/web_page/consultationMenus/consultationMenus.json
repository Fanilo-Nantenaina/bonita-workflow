    "menusAvecLibelleDisponibilite" : {
      "type" : "expression",
      "value" : [
        "if ($data.hasOwnProperty('menus') && $data.menus) {",
        "    for (let menu of $data.menus) {",
        "        if (menu.disponible === true) {",
        "            menu.disponibleLabel = \"Disponible\";",
        "        } else if (menu.disponible === false) {",
        "            menu.disponibleLabel = \"Indisponible\";",
        "        } else {",
        "            menu.disponibleLabel = \"Non renseigné\";",
        "        }",
        "    }",
        "}",
        "return $data.menus;"
      ],
