              <parameters xmi:type="connectorconfiguration:ConnectorParameter" xmi:id="_Kr2zo1i7EfGcr_ZmOb_yGw" key="message">
                <expression xmi:type="expression:Expression" xmi:id="_Kr2zpFi7EfGcr_ZmOb_yGw" name="message()" content="&quot;&quot;&quot;&lt;html>&lt;body>&#xD;&#xA;&lt;p>Bonjour,&lt;/p>&#xD;&#xA;&lt;p>Une chambre est à nettoyer et à remettre en état :&lt;/p>&#xD;&#xA;&lt;ul>&#xD;&#xA;  &lt;li>Numéro de chambre : &lt;strong>${chambreChoisie?.numero ?: '-'}&lt;/strong>&lt;/li>&#xD;&#xA;  &lt;li>Catégorie : &lt;strong>${chambreChoisie?.categorie ?: '-'}&lt;/strong>&lt;/li>&#xD;&#xA;  &lt;li>Date de fin de séjour : &lt;strong>${reservation?.dateArrivee?.plusDays(reservation?.nombreNuits ?: 0) ?: '-'}&lt;/strong>&lt;/li>&#xD;&#xA;&lt;/ul>&#xD;&#xA;&lt;p>Merci de procéder au ménage et au remplacement des articles de dotation (gel douche, papier hygiénique, pantoufles, brosse à dents).&lt;/p>&#xD;&#xA;&lt;p>Cordialement,&lt;br/>La Réception&lt;/p>&#xD;&#xA;&lt;/body>&lt;/html>&quot;&quot;&quot;" interpreter="GROOVY" type="TYPE_READ_ONLY_SCRIPT" returnTypeFixed="true">
