      <contract xmi:type="process:Contract" xmi:id="_mM71zFfFEfGNssooKuF_YA">
        <inputs xmi:type="process:ContractInput" xmi:id="_KqoakFiyEfGcr_ZmOb_yGw" name="typeServiceInput" description="Choix client à l'instanciation : CHAMBRE ou RESTO. Pilote la XOR juste après le StartEvent">
          <mapping xmi:type="process:ContractInputMapping" xmi:id="_KqoakViyEfGcr_ZmOb_yGw"/>
        </inputs>
        <inputs xmi:type="process:ContractInput" xmi:id="_ZpTZUFiyEfGcr_ZmOb_yGw" name="clientLogeInput" type="BOOLEAN" description="Si typeServiceInput=RESTO : true si le client est logé à l'hôtel (bascule vers facture chambre). Null si CHAMBRE">
          <mapping xmi:type="process:ContractInputMapping" xmi:id="_ZpTZUViyEfGcr_ZmOb_yGw"/>
        </inputs>
        <constraints xmi:type="process:ContractConstraint" xmi:id="_m3TEoFiyEfGcr_ZmOb_yGw" expression="typeServiceInput != null" errorMessage="Le type de service est obligatoire." name="typeServiceInputRequired">
          <inputNames>typeServiceInput</inputNames>
        </constraints>
        <constraints xmi:type="process:ContractConstraint" xmi:id="_oHzDMFiyEfGcr_ZmOb_yGw" expression="typeServiceInput == null || typeServiceInput in ['CHAMBRE', 'RESTO']" errorMessage="Type de service invalide : CHAMBRE ou RESTO attendu." name="typeServiceInputValid">
          <inputNames>typeServiceInput</inputNames>
        </constraints>
        <constraints xmi:type="process:ContractConstraint" xmi:id="_sQbsgFiyEfGcr_ZmOb_yGw" expression="typeServiceInput != 'RESTO' || clientLogeInput != null" errorMessage="L'information &quot;client logé&quot; est obligatoire si le type de service est RESTO." name="clientLogeInputRequiredIfResto">
          <inputNames>clientLogeInput</inputNames>
          <inputNames>typeServiceInput</inputNames>
        </constraints>
      </contract>
