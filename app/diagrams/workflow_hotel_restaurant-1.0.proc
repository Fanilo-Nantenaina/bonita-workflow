              <parameters xmi:type="connectorconfiguration:ConnectorParameter" xmi:id="_Kr2zmFi7EfGcr_ZmOb_yGw" key="to">
                <expression xmi:type="expression:Expression" xmi:id="_Kr2zmVi7EfGcr_ZmOb_yGw" name="emailDestinataire()" content="import org.bonitasoft.engine.identity.User&#xD;&#xA;import org.bonitasoft.engine.identity.UserCriterion&#xD;&#xA;&#xD;&#xA;def role = apiAccessor.identityAPI.getRoleByName(&quot;FemmeDeMenage&quot;)&#xD;&#xA;List&lt;User> users = apiAccessor.identityAPI.getUsersInRole(role.getId(), 0, 100, UserCriterion.USER_NAME_ASC)&#xD;&#xA;&#xD;&#xA;return users.collect { user ->&#xD;&#xA;    apiAccessor.identityAPI.getUserContactData(user.getId(), false)?.getEmail()&#xD;&#xA;}.findAll { it != null &amp;&amp; !it.isEmpty() }.join(&quot;,&quot;)" interpreter="GROOVY" type="TYPE_READ_ONLY_SCRIPT" returnTypeFixed="true">
                  <referencedElements xmi:type="expression:Expression" xmi:id="_4gvlkFjIEfGNAs_r4dbEXA" name="apiAccessor" content="apiAccessor" type="TYPE_ENGINE_CONSTANT" returnType="org.bonitasoft.engine.api.APIAccessor"/>
