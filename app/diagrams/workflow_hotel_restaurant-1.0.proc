      <data xmi:type="process:BusinessObjectData" xmi:id="_FF5jIFhkEfG7wIzUbyU7wQ" documentation="Commande restaurant initiée par un client (logé ou extérieur). Créée dans la tâche Soumettre si le client choisit RESTO, reste null pour les workflows CHAMBRE." name="commandeResto" dataType="_mM715FfFEfGNssooKuF_YA" className="com.company.model.CommandeResto">
        <defaultValue xmi:type="expression:Expression" xmi:id="_FF6KMFhkEfG7wIzUbyU7wQ" name="init_commandeResto()" content="import java.time.LocalDateTime&#xD;&#xA;&#xD;&#xA;import org.bonitasoft.engine.identity.UserNotFoundException&#xD;&#xA;&#xD;&#xA;if (typeServiceInput != 'RESTO') {&#xD;&#xA;    return null&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;try{&#xD;&#xA;&#x9;def processInitiator = apiAccessor.getIdentityAPI().getUser(apiAccessor.getProcessAPI()&#xD;&#xA;&#x9;&#x9;&#x9;.getProcessInstance(processInstanceId)&#xD;&#xA;&#x9;&#x9;&#x9;.getStartedBy())&#xD;&#xA;&#x9;&#x9;&#x9;&#xD;&#xA;&#x9;def commandeRestoVar = new com.company.model.CommandeResto()&#xD;&#xA;&#x9;commandeRestoVar.idClient = processInitiator.id&#xD;&#xA;&#x9;commandeRestoVar.dateCommande = LocalDateTime.now()&#xD;&#xA;&#x9;commandeRestoVar.statut = 'OUVERTE'&#xD;&#xA;&#x9;commandeRestoVar.montantTotal = 0.0d&#xD;&#xA;&#x9;commandeRestoVar.modePaiement = clientLogeInput ? 'BASCULE' : 'CASH'&#xD;&#xA;&#xD;&#xA;&#x9;if (clientLogeInput) {&#xD;&#xA;&#x9;&#x9;def reservations = reservationDAO.findActiveByClient(processInitiator.id, 0, 1)&#xD;&#xA;&#x9;&#x9;if (reservations != null &amp;&amp; !reservations.isEmpty()) {&#xD;&#xA;&#x9;&#x9;&#x9;commandeRestoVar.idReservationAssociee = reservations[0].persistenceId&#xD;&#xA;&#x9;&#x9;}&#xD;&#xA;&#x9;}&#xD;&#xA;&#xD;&#xA;&#x9;return commandeRestoVar&#xD;&#xA;&#x9;&#xD;&#xA;}catch(UserNotFoundException e){&#xD;&#xA;&#x9;throw new RuntimeException(&quot;Impossible de récupérer l'initiateur du processus : &quot; + e.getMessage(), e)&#xD;&#xA;}&#xD;&#xA;" interpreter="GROOVY" type="TYPE_READ_ONLY_SCRIPT" returnType="com.company.model.CommandeResto">
          <referencedElements xmi:type="process:ContractInput" xmi:id="_RiQu0Fi0EfGcr_ZmOb_yGw" name="typeServiceInput" description="Choix client à l'instanciation : CHAMBRE ou RESTO. Pilote la XOR juste après le StartEvent">
            <mapping xmi:type="process:ContractInputMapping" xmi:id="_RiQu0Vi0EfGcr_ZmOb_yGw"/>
          </referencedElements>
          <referencedElements xmi:type="expression:Expression" xmi:id="_RiR88Fi0EfGcr_ZmOb_yGw" name="processInstanceId" content="processInstanceId" type="TYPE_ENGINE_CONSTANT" returnType="java.lang.Long"/>
          <referencedElements xmi:type="expression:Expression" xmi:id="_RiR88Vi0EfGcr_ZmOb_yGw" name="apiAccessor" content="apiAccessor" type="TYPE_ENGINE_CONSTANT" returnType="org.bonitasoft.engine.api.APIAccessor"/>
          <referencedElements xmi:type="expression:Expression" xmi:id="_RiR88li0EfGcr_ZmOb_yGw" name="reservationDAO" content="reservationDAO" type="TYPE_BUSINESS_OBJECT_DAO" returnType="com.company.model.ReservationDAO" returnTypeFixed="true"/>
          <referencedElements xmi:type="process:ContractInput" xmi:id="_RiR881i0EfGcr_ZmOb_yGw" name="clientLogeInput" type="BOOLEAN" description="Si typeServiceInput=RESTO : true si le client est logé à l'hôtel (bascule vers facture chambre). Null si CHAMBRE">
            <mapping xmi:type="process:ContractInputMapping" xmi:id="_RiR89Fi0EfGcr_ZmOb_yGw"/>
