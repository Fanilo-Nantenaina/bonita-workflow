                <expression xmi:type="expression:Expression" xmi:id="_Kr2zlVi7EfGcr_ZmOb_yGw" name="emailExpediteur()" content="import org.bonitasoft.engine.identity.User&#xD;&#xA;import org.bonitasoft.engine.identity.UserCriterion&#xD;&#xA;&#xD;&#xA;def role = apiAccessor.identityAPI.getRoleByName(&quot;Receptionniste&quot;)&#xD;&#xA;List&lt;User> users = apiAccessor.identityAPI.getUsersInRole(role.getId(), 0, 1, UserCriterion.USER_NAME_ASC)&#xD;&#xA;&#xD;&#xA;if (users == null || users.isEmpty()) {&#xD;&#xA;    return &quot;noreply@hotelrestaurant.mg&quot;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;def email = apiAccessor.identityAPI.getUserContactData(users[0].getId(), false)?.getEmail()&#xD;&#xA;return (email != null &amp;&amp; !email.isEmpty()) ? email : &quot;noreply@hotelrestaurant.mg&quot;" interpreter="GROOVY" type="TYPE_READ_ONLY_SCRIPT" returnTypeFixed="true">
                  <referencedElements xmi:type="expression:Expression" xmi:id="_4gu-gFjIEfGNAs_r4dbEXA" name="apiAccessor" content="apiAccessor" type="TYPE_ENGINE_CONSTANT" returnType="org.bonitasoft.engine.api.APIAccessor"/>
